{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-app",
  "version": "2.9.11",
  "identifier": "com.tauri-app.my",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "tauri-app",
        "decorations": false,
        "width": 1440,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 800
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost",
        "font-src": "'self",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "style-src": "'unsafe-inline' 'self'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "resources": []
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/aifuqiang02/tauri-vue-template/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFFODE1OTFEOERFMzU3NUQKUldSZFYrT05IVm1Ccm9kY1BPb3JQMUREMWd1V2RFMHkvTVo2NXEvVTJITHFJSGFrSHpSQnBYOXQK"
    }
  }
}
